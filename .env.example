PORT=4567
DIALOGFLOW_PROJECT_ID=qualityassistant-ygdm
PUBLIC_BASE_URL=https://es-based-chatbot-production.up.railway.app

# Local: save service account JSON as credentials.json
# GOOGLE_APPLICATION_CREDENTIALS=./credentials.json

# Railway: paste FULL service-account JSON as ONE line (no file upload)
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"qualityassistant-ygdm",...}
#
# Or base64-encode the JSON file (avoids paste/newline issues):
# GOOGLE_CREDENTIALS_JSON_BASE64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Ii...

# Google Sheets
# SHEETS_SPREADSHEET_ID=
# SHEETS_RANGE=Sheet1!A:AG

# Google Drive (upload form) — parent folder id from Drive URL
# GOOGLE_DRIVE_FOLDER_ID=
# Optional OAuth for My Drive: GOOGLE_DRIVE_OAUTH_CLIENT_ID, GOOGLE_DRIVE_OAUTH_CLIENT_SECRET, GOOGLE_DRIVE_OAUTH_REFRESH_TOKEN
# CONTACT_FORM_SUBMISSION_TZ=Asia/Kolkata
