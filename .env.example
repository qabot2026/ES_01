# Railway: paste FULL service-account JSON as ONE line
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}

# Google Sheets — one spreadsheet for all bots
# SHEETS_SPREADSHEET_ID=
# SHEETS_RANGE=Sheet1!A:AG
# Live-agent handoffs from all bots (tab created automatically if missing)
# SHEETS_AGENT_TAB=Agent Chats
# Per-bot conversation tabs are set in Dashboard → Advanced configuration

# Google Cloud Storage (upload form)
# GCS_BUCKET_NAME=your-bucket-name
# GCS_UPLOAD_PREFIX=uploads
# GCS_SIGNED_URL_DAYS=7
# CONTACT_FORM_SUBMISSION_TZ=Asia/Kolkata
